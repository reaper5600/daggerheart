---
{"dg-publish":true,"permalink":"/quest-board.canvas/","contentClasses":"canvas-page"}
---

<div id="Quest_Boardcanvas" class="canvas-wrapper hide">
	<svg class="canvas-background">
		<defs>
			<pattern id="canvas-grid-Quest_Boardcanvas" width="25" height="25" patternUnits="userSpaceOnUse">
				<circle r="1.5" cx="12.5" cy="12.5"></circle>
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#canvas-grid-Quest_Boardcanvas)"></rect>
	</svg>
	<div class="canvas">
		<svg class="canvas-edges-container" style="position:absolute;width:1px;height:1px;overflow:visible;">
			<defs><filter x="-0.1" y="-0.1" width="1.2" height="1.3" id="edge-label-bg">
			<feFlood flood-color="var(--background-primary)" flood-opacity="1" result="bg"/>
			<feMerge>
				<feMergeNode in="bg"/>
				<feMergeNode in="SourceGraphic"/>
			</feMerge>
		</filter></defs>
		</svg>
		<div class="canvas-node canvas-node-group " data-node-id="83ea42b187cc3b23" style="transform: translate(540px, -540px); width: 620px; height: 780px;  ">
	<div class="canvas-node-label">IN PROGRESS</div>
</div>
<div class="canvas-node canvas-node-text has-color" data-node-id="d0ec97edad285fdb" style="transform: translate(-180px, -570px); width: 340px; height: 423px; --canvas-color: #44cf6e;">
	<div class="canvas-node-container">
		<div class="canvas-node-content markdown-rendered">
